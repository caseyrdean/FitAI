generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default("local-user")
  createdAt DateTime @default(now())

  healthProfile  HealthProfile?
  mealPlans      MealPlan[]
  foodLogEntries FoodLogEntry[]
  bloodWorkRecords BloodWorkRecord[]
  workoutPlans   WorkoutPlan[]
  workoutSessions WorkoutSession[]
  progressEntries ProgressEntry[]
  conversations  AtlasConversation[]
  supplementAdvice SupplementAdvice?
  weeklyScores   WeeklyScore[]
  personalizationMemory PersonalizationMemory?
  personalizationMemoryEvents PersonalizationMemoryEvent[]
  notifications Notification[]
}

model HealthProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  goals               String   @default("")
  fitnessLevel        String   @default("")
  conditions          String[] @default([])
  injuries            String[] @default([])
  dietaryRestrictions String[] @default([])
  foodPreferences     String   @default("")
  onboardingComplete  Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model MealPlan {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  weekStart    DateTime
  meals        Json
  shoppingList Json
  macroTargets Json
  prepGuide    Json
  createdAt    DateTime @default(now())

  @@index([userId, weekStart])
}

model FoodLogEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  loggedAt    DateTime @default(now())
  description String
  mealType    String
  /** "food" | "supplement" — supplements roll into micronutrient totals; macros usually zero. */
  entryKind   String   @default("food")
  nutrients   Json
  createdAt   DateTime @default(now())

  @@index([userId, loggedAt])
}

/** Atlas-generated supplement recommendations (diet gaps + blood work); generic forms only, no brands. */
model SupplementAdvice {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  weekStart DateTime?
  items     Json
  summary   String    @default("")
  updatedAt DateTime  @updatedAt
}

model BloodWorkRecord {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  uploadedAt DateTime  @default(now())
  filePath   String
  rawText    String    @default("")
  parsedAt   DateTime?
  markers    BloodWorkMarker[]

  @@index([userId])
}

model BloodWorkMarker {
  id           String  @id @default(cuid())
  recordId     String
  record       BloodWorkRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  /** Lab panel / section title from the report, e.g. "Lipid Panel, Standard". */
  category     String  @default("")
  name         String
  value        Float
  unit         String
  referenceMin Float?
  referenceMax Float?
  /** Lab Flag column as printed: H, L, HH, LL, etc. */
  labFlag      String?
  flagged      Boolean @default(false)
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weekStart DateTime
  days      Json
  createdAt DateTime @default(now())

  @@index([userId, weekStart])
}

model WorkoutSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  planDayRef  String
  completed   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model ProgressEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  weight      Float?
  energyLevel Int?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model AtlasConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("chat")
  messages  AtlasMessage[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model AtlasMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   AtlasConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolCalls      Json?
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model WeeklyScore {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  weekStart        DateTime
  overallScore     Int
  nutritionScore   Int
  workoutScore     Int
  checkinScore     Int
  consistencyScore Int?
  summary          String   @default("")
  coachingRecap    String   @default("")
  highlights       Json
  actionItems      Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId, createdAt])
}

model PersonalizationMemory {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  memory    Json
  version   Int      @default(1)
  updatedBy String   @default("atlas")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonalizationMemoryEvent {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  personalizationMemoryId String?
  eventType           String
  updatedBy           String
  payload             Json
  createdAt           DateTime @default(now())

  @@index([userId, createdAt])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  type       String
  title      String
  message    String
  payload    Json?
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, dismissed, createdAt])
}
